# LLM — required
# The model string follows LiteLLM's format: provider/model-name
# See README for a full list of supported providers and their API key variables
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini/gemini-3.0-flash-preview

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=signals
DEFAULT_INTERVAL_MINUTES=60

# Auth — JWT secret (required)
JWT_SECRET=change-me

# Langfuse — optional, enables LLM tracing (https://cloud.langfuse.com or self-hosted)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

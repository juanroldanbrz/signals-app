# LLM — choose ONE of the two options below:

# Option A: API-key provider (Google AI Studio, OpenAI, Anthropic, …)
# The model string follows LiteLLM's format: provider/model-name
# See README for a full list of supported providers
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini/gemini-2.5-flash

# Option B: Google Vertex AI (leave LLM_API_KEY empty or omit it)
# LLM_MODEL=vertex_ai/gemini-2.0-flash
# VERTEXAI_PROJECT=your-gcp-project-id
# VERTEXAI_LOCATION=us-central1
# VERTEXAI_CREDENTIALS={"type":"service_account","project_id":"..."}   ← paste full JSON on one line

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=signals
DEFAULT_INTERVAL_MINUTES=60

# Auth — JWT secret (required)
JWT_SECRET=change-me

# Email verification — optional (default: false)
# Set MANDATORY_EMAIL_VERIFICATION=true in production to require email confirmation on signup.
# Requires a Resend account (https://resend.com) and a verified sender domain.
# MANDATORY_EMAIL_VERIFICATION=true
# RESEND_API_KEY=re_...

# Langfuse — optional, enables LLM tracing (https://cloud.langfuse.com or self-hosted)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
